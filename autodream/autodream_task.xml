<?xml version="1.0" encoding="UTF-16"?>
<!--
  AutoDream Nightly Task — Windows Task Scheduler
  Import via: schtasks /create /xml autodream_task.xml /tn "Studio\AutoDream"
  Or: Task Scheduler GUI > Action > Import Task
  Path: G:\My Drive\Projects\_studio\scripts\autodream_task.xml
-->
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>AutoDream: Nightly studio memory consolidation. Reads supervisor logs and inbox answers, distills key facts via Claude Haiku, upserts to ChromaDB. Also computes project health scores.</Description>
    <Author>Studio Supervisor</Author>
    <Date>2026-04-04T00:00:00</Date>
  </RegistrationInfo>
  <Triggers>
    <CalendarTrigger>
      <StartBoundary>2026-04-05T02:00:00</StartBoundary>
      <Enabled>true</Enabled>
      <ScheduleByDay>
        <DaysInterval>1</DaysInterval>
      </ScheduleByDay>
    </CalendarTrigger>
  </Triggers>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>false</RunOnlyIfNetworkAvailable>
    <IdleSettings>
      <StopOnIdleEnd>false</StopOnIdleEnd>
      <RestartOnIdle>false</RestartOnIdle>
    </IdleSettings>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <RunOnlyIfIdle>false</RunOnlyIfIdle>
    <WakeToRun>false</WakeToRun>
    <ExecutionTimeLimit>PT1H</ExecutionTimeLimit>
    <Priority>7</Priority>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <Command>python</Command>
      <Arguments>G:\My Drive\Projects\_studio\scripts\autodream.py</Arguments>
      <WorkingDirectory>G:\My Drive\Projects\_studio\scripts</WorkingDirectory>
    </Exec>
  </Actions>
</Task>

<!--
HAMILTON RULE COMPLIANCE:
TTL: 1 hour execution limit (PT1H above)
If autodream fails, check: logs\autodream.log
Supervisor inbox alert: autodream_fail item (see CLAUDE.md AutoDream Rule)
Manual re-run: python G:\My Drive\Projects\_studio\scripts\autodream.py
-->
