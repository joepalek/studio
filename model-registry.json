{
  "_meta": {
    "version": "2.0.1",
    "updated": "2026-04-05",
    "description": "Studio AI Model Registry — Supervisor routing source of truth",
    "note": "Supervisor reads this file to select model/engine per task. Cost tiers guide offload decisions."
  },

  "engines": {
    "clawcode_ollama": {
      "type": "local_harness",
      "binary": "C:\\tools\\claw\\claw.exe",
      "provider": "ollama",
      "base_url": "http://localhost:11434",
      "api_cost_per_1k_tokens": 0.00,
      "status": "available",
      "requires_gpu": false,
      "note": "ClawCode-local Rust build pointed at Ollama. Zero API cost. Use for scraping scripts, boilerplate, formatters, one-shot tasks. See Lovelace Rule in CLAUDE.md.",
      "approved_task_types": [
        "scraper",
        "boilerplate",
        "formatter",
        "test_writer",
        "one_shot_script",
        "data_parser",
        "html_extractor",
        "game_arch_pipeline_script"
      ],
      "default_model": "qwen3:14b",
      "fallback_model": "qwen3.5:27b",
      "max_output_lines": 150,
      "tool_calling_support": true
    },

    "anthropic_api": {
      "type": "cloud_api",
      "provider": "anthropic",
      "api_cost_per_1k_tokens": "varies_by_model",
      "status": "available",
      "note": "Primary cloud provider. Route via ai_gateway.py task_type mapping."
    },

    "gemini_api": {
      "type": "cloud_api",
      "provider": "google",
      "api_cost_per_1k_tokens": "varies_by_model",
      "status": "available",
      "note": "Secondary cloud provider. Use for vision tasks, large context windows."
    },

    "ollama_direct": {
      "type": "local_inference",
      "base_url": "http://localhost:11434",
      "api_cost_per_1k_tokens": 0.00,
      "status": "available",
      "note": "Direct Ollama API calls without ClawCode harness. Use for ChromaDB RAG, embeddings, quick classification. Anthropic-compatible endpoint available via /v1."
    }
  },

  "models": {
    "claude-opus-4-6": {
      "engine": "anthropic_api",
      "tier": "premium",
      "cost_per_1k_input": 0.015,
      "cost_per_1k_output": 0.075,
      "context_window": 200000,
      "task_types": ["planning", "architecture", "complex_reasoning", "quality_review"],
      "supervisor_rule": "PLANNING_GATE tasks only (Watkins Rule). Require explicit approval for runs > 5k tokens."
    },

    "claude-sonnet-4-6": {
      "engine": "anthropic_api",
      "tier": "standard",
      "cost_per_1k_input": 0.003,
      "cost_per_1k_output": 0.015,
      "context_window": 200000,
      "task_types": ["agent_coordination", "inbox_decisions", "content_generation", "ebay_listings", "multi_step_reasoning"],
      "supervisor_rule": "Default workhorse model. Primary engine for all mid-complexity tasks."
    },

    "claude-haiku-4-5-20251001": {
      "engine": "anthropic_api",
      "tier": "economy",
      "cost_per_1k_input": 0.00025,
      "cost_per_1k_output": 0.00125,
      "context_window": 200000,
      "task_types": ["classification", "extraction", "summarization", "autodream_distillation", "health_scoring", "inbox_triage"],
      "supervisor_rule": "AutoDream nightly distillation runs on Haiku exclusively. Also use for high-volume classification where Sonnet is overkill."
    },

    "gemini-2.5-pro": {
      "engine": "gemini_api",
      "tier": "premium",
      "context_window": 1000000,
      "task_types": ["large_document_analysis", "vision_complex", "gaussian_splat_prep"],
      "supervisor_rule": "Use when context > 150k tokens or task involves image batch processing."
    },

    "gemini-2.0-flash": {
      "engine": "gemini_api",
      "tier": "standard",
      "context_window": 1000000,
      "task_types": ["vision_standard", "fast_extraction", "game_arch_ocr"],
      "supervisor_rule": "Game Archaeology vision tasks default here. Fast and cheap for image analysis."
    },

    "qwen3:14b": {
      "engine": "clawcode_ollama",
      "tier": "free_local",
      "cost_per_1k_tokens": 0.00,
      "context_window": 32768,
      "task_types": ["scraper", "boilerplate", "formatter", "one_shot_script", "data_parser"],
      "supervisor_rule": "Primary ClawCode model. Invoke via Lovelace Rule. Strong tool-calling at this size. Default for all approved ClawCode task types.",
      "tool_calling": "reliable"
    },

    "qwen3.5:27b": {
      "engine": "clawcode_ollama",
      "tier": "free_local",
      "cost_per_1k_tokens": 0.00,
      "context_window": 32768,
      "task_types": ["scraper_complex", "multi_function_script", "html_extractor_large"],
      "supervisor_rule": "ClawCode fallback when qwen3:14b produces incomplete output or task prompt > 2000 tokens.",
      "tool_calling": "reliable"
    },

    "qwen3:8b": {
      "engine": "ollama_direct",
      "tier": "free_local",
      "cost_per_1k_tokens": 0.00,
      "context_window": 32768,
      "task_types": ["quick_classification", "embedding_assist", "chromadb_query_rewrite"],
      "supervisor_rule": "Direct Ollama only (not ClawCode). Use for sub-tasks within pipeline steps where a full harness is overkill.",
      "tool_calling": "unreliable_at_this_size"
    }
  },

  "task_routing_table": {
    "_note": "Supervisor evaluates task_type first, then complexity, then cost_gate",

    "scraper":                  {"primary": "qwen3:14b",            "engine": "clawcode_ollama",  "fallback": "claude-sonnet-4-6"},
    "boilerplate":              {"primary": "qwen3:14b",            "engine": "clawcode_ollama",  "fallback": "claude-haiku-4-5-20251001"},
    "formatter":                {"primary": "qwen3:14b",            "engine": "clawcode_ollama",  "fallback": "claude-haiku-4-5-20251001"},
    "one_shot_script":          {"primary": "qwen3:14b",            "engine": "clawcode_ollama",  "fallback": "claude-sonnet-4-6"},
    "data_parser":              {"primary": "qwen3:14b",            "engine": "clawcode_ollama",  "fallback": "claude-haiku-4-5-20251001"},
    "game_arch_pipeline_script":{"primary": "qwen3:14b",            "engine": "clawcode_ollama",  "fallback": "claude-sonnet-4-6"},
    "html_extractor":           {"primary": "qwen3:14b",            "engine": "clawcode_ollama",  "fallback": "gemini-2.0-flash"},

    "classification":           {"primary": "claude-haiku-4-5-20251001", "engine": "anthropic_api", "fallback": "qwen3:8b"},
    "extraction":               {"primary": "claude-haiku-4-5-20251001", "engine": "anthropic_api", "fallback": "qwen3:8b"},
    "summarization":            {"primary": "claude-haiku-4-5-20251001", "engine": "anthropic_api", "fallback": "qwen3:14b"},
    "autodream_distillation":   {"primary": "claude-haiku-4-5-20251001", "engine": "anthropic_api", "fallback": null},
    "inbox_triage":             {"primary": "claude-haiku-4-5-20251001", "engine": "anthropic_api", "fallback": null},

    "agent_coordination":       {"primary": "claude-sonnet-4-6",    "engine": "anthropic_api",    "fallback": null},
    "inbox_decisions":          {"primary": "claude-sonnet-4-6",    "engine": "anthropic_api",    "fallback": null},
    "content_generation":       {"primary": "claude-sonnet-4-6",    "engine": "anthropic_api",    "fallback": "gemini-2.0-flash"},
    "ebay_listings":            {"primary": "claude-sonnet-4-6",    "engine": "anthropic_api",    "fallback": null},
    "multi_step_reasoning":     {"primary": "claude-sonnet-4-6",    "engine": "anthropic_api",    "fallback": "gemini-2.5-pro"},

    "planning":                 {"primary": "claude-opus-4-6",      "engine": "anthropic_api",    "fallback": "claude-sonnet-4-6"},
    "architecture":             {"primary": "claude-opus-4-6",      "engine": "anthropic_api",    "fallback": "claude-sonnet-4-6"},
    "complex_reasoning":        {"primary": "claude-opus-4-6",      "engine": "anthropic_api",    "fallback": "claude-sonnet-4-6"},

    "vision_standard":          {"primary": "gemini-2.0-flash",     "engine": "gemini_api",       "fallback": "claude-sonnet-4-6"},
    "vision_complex":           {"primary": "gemini-2.5-pro",       "engine": "gemini_api",       "fallback": "claude-sonnet-4-6"},
    "large_document_analysis":  {"primary": "gemini-2.5-pro",       "engine": "gemini_api",       "fallback": "claude-sonnet-4-6"},
    "gaussian_splat_prep":      {"primary": "gemini-2.5-pro",       "engine": "gemini_api",       "fallback": null}
  },

  "cost_gates": {
    "_note": "Supervisor enforces these before dispatching any task",
    "opus_requires_approval_above_tokens": 5000,
    "sonnet_daily_budget_usd": 5.00,
    "haiku_daily_budget_usd": 2.00,
    "clawcode_ollama_budget_usd": 0.00,
    "alert_supervisor_if_daily_spend_exceeds_usd": 8.00
  },

  "clawcode_install": {
    "_note": "One-time setup completed 2026-04-05. ClawCode is live at C:\\tools\\claw\\claw.exe",
    "repo": "https://github.com/codetwentyfive/claw-code-local",
    "install_location": "C:\\tools\\claw-src",
    "binary_location": "C:\\tools\\claw\\claw.exe",
    "build_steps": [
      "git clone https://github.com/codetwentyfive/claw-code-local.git C:\\tools\\claw-src",
      "cd C:\\tools\\claw-src\\rust",
      "cargo build -p rusty-claude-cli --release",
      "copy rust\\target\\release\\claw.exe C:\\tools\\claw\\claw.exe"
    ],
    "env_vars_set": {
      "OPENAI_BASE_URL": "http://127.0.0.1:11434/v1",
      "OPENAI_API_KEY": "ollama",
      "OPENAI_MODEL": "qwen3:14b"
    },
    "ollama_models_pulled": [
      "qwen3:14b",
      "qwen3:27b",
      "qwen3:8b"
    ],
    "test_command": "claw --model qwen3:14b \"write a Python function that returns the current timestamp\"",
    "status": "verified_working"
  }
}
