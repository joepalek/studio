{
  "system": "Master Asset Creation & Distribution Router",
  "version": "1.0",
  "last_updated": "2026-03-30",
  "created_by": "Joe Palek",
  "purpose": "Route all agent-created assets to destinations, validate via CX Agent, track usage",
  
  "creator_agents": {
    "eBay_Listing_Agent": {
      "creates": "product listings (JSON schema)",
      "validation_rules": ["format", "quality_score", "brand_alignment"],
      "routing": {
        "destination": "eBay API",
        "upload_protocol": "OAuth2 batch endpoint",
        "quality_threshold": 8,
        "fallback_on_fail": "staging_review (whiteboard)"
      },
      "usage_tracking": {
        "monitor": "listing_views, conversion_rate, feedback",
        "reporting_cadence": "daily",
        "social_signal": "high_performers_to_feed"
      }
    },
    
    "CTW_Agent": {
      "creates": ["app", "script", "mp4", "jpg", "excel", "character_files"],
      "validation_rules": ["format", "quality_score", "brand_alignment"],
      "routing": {
        "rule_1": {
          "condition": "output_type IN (app, script, mp4, jpg, excel)",
          "destination": "project_folder/{project_name}",
          "example": "G:/My Drive/Projects/CTW/character_builder/outputs/"
        },
        "rule_2": {
          "condition": "output_type == character_file",
          "destination": "characters_final_folder",
          "location": "G:/My Drive/Projects/CTW/characters_final/",
          "sub_destinations": ["viewer_access", "mirofish_queries", "api_endpoints"]
        }
      },
      "quality_threshold": 8,
      "usage_tracking": {
        "monitor": "character_adoption_rate, viewer_loads, api_query_frequency",
        "reporting_cadence": "daily",
        "social_signal": "trending_characters_for_marketing"
      }
    },
    
    "Ghost_Book_Agent": {
      "creates": ["scripts", "books", "story_content"],
      "validation_rules": ["format", "quality_score", "brand_alignment"],
      "routing": {
        "draft_stage": {
          "condition": "status == draft OR newly_created",
          "destination": "G:/My Drive/Projects/Ghost_Book/scripts_books_draft/",
          "purpose": "available for consumption by new creation processes",
          "consumable_by": ["Ghost_Book_Agent", "CTW_Agent", "Content_Distribution"]
        },
        "done_stage": {
          "condition": "status == complete AND ready_for_release",
          "destination": "G:/My Drive/Projects/Ghost_Book/done_books_scripts/",
          "purpose": "finalized, awaiting release decision",
          "quality_threshold": 9
        },
        "final_stage": {
          "condition": "status == released OR approved_for_market",
          "destination": "G:/My Drive/Projects/Ghost_Book/final_books_scripts/",
          "purpose": "live content for market distribution or video creation",
          "sub_destinations": ["market_distribution", "video_creation_feed"]
        }
      },
      "quality_threshold": 8,
      "usage_tracking": {
        "monitor": "downloads, reads, video_views, market_performance",
        "reporting_cadence": "daily",
        "social_signal": "trending_content_for_amplification"
      }
    },
    
    "Jobs_Agent": {
      "creates": ["job_postings", "job_metadata"],
      "validation_rules": ["format", "quality_score", "brand_alignment"],
      "routing": {
        "destination": "G:/My Drive/Projects/Job_Match/jobs_repository/",
        "purpose": "central job depository for Job_Match app to query"
      },
      "maintenance": {
        "daily_cull": {
          "rule": "remove expired or no_longer_listed jobs",
          "schedule": "every_24_hours",
          "agent_responsible": "Jobs_Agent OR CX_Agent (daily_audit)"
        }
      },
      "quality_threshold": 7,
      "usage_tracking": {
        "monitor": "job_impressions, application_rate, position_fill_time",
        "reporting_cadence": "daily",
        "social_signal": "high_demand_roles_for_promotion"
      }
    }
  },

  "cx_agent_workflow": {
    "role": "Asset Quality Gate & Distribution Traffic Cop",
    "incoming": "all_creator_agent_outputs",
    "process": [
      {
        "step": 1,
        "action": "receive_asset",
        "input": "asset_metadata + content",
        "validation": ["format_check", "quality_score", "brand_alignment_check"]
      },
      {
        "step": 2,
        "action": "grade_asset",
        "scoring": {
          "format_check": "pass/fail (schema validation)",
          "quality_score": "1-10 scale",
          "brand_alignment": "pass/fail (tone, values, visual consistency)",
          "overall_status": "pass (>=8) OR review (5-7) OR reject (<5)"
        }
      },
      {
        "step": 3,
        "action": "route_asset",
        "logic": "consult asset_distribution_manifest.json for destination",
        "delivery": "push to final_destination OR staging_for_review"
      },
      {
        "step": 4,
        "action": "track_usage",
        "monitor": "where asset goes, how it performs, where it's consumed",
        "logging": "asset_creation_log.json"
      },
      {
        "step": 5,
        "action": "feed_social_intel",
        "output": "performance_signals to social_media_agent",
        "examples": [
          "high_conversion_listings → promote_on_social",
          "trending_characters → create_character_spotlight_content",
          "popular_books → feature_on_newsletter_or_youtube"
        ]
      }
    ],
    "output": "asset_creation_log entry + usage_telemetry",
    "escalation": "quality_fails or_routing_errors → whiteboard for manual review"
  },

  "validation_thresholds": {
    "pass": "format ✓ + quality >= 8 + brand_alignment ✓",
    "review": "format ✓ + (quality 5-7 OR brand_alignment ✗)",
    "reject": "format ✗ OR quality < 5"
  }
}
