<?xml version="1.0" encoding="UTF-16"?>
<!--
  TASK SCHEDULER XML TEMPLATE — Tier 1 Pipeline Agent
  =====================================================
  HOW TO REGISTER:
    schtasks /Create /XML "G:\My Drive\Projects\_studio\scheduler\tier1-template.xml" /TN "\Studio\AGENT_ID" /F

  HOW TO TEST IMMEDIATELY:
    schtasks /Run /TN "\Studio\AGENT_ID"

  HOW TO CHECK STATUS:
    schtasks /Query /TN "\Studio\AGENT_ID" /FO LIST

  REPLACE BEFORE USING:
    AGENT_ID        → e.g. SanctionsIngestor
    AGENT_SCRIPT    → e.g. sanctions_ingestor.py
    TRIGGER_HOUR    → 0-23 (use 2 for 2 AM)
    TRIGGER_MINUTE  → 0-59
    EXPECTED_RUNTIME_SECONDS → Hamilton Rule declaration (matches ttl_seconds in CONFIG)
-->
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Tier 1 Pipeline: AGENT_ID | Pool #POOL_NUMBER | Expected runtime: EXPECTED_RUNTIME_SECONDS s | Hamilton TTL enforced in script</Description>
    <Author>Studio</Author>
  </RegistrationInfo>

  <Triggers>
    <CalendarTrigger>
      <!-- Daily trigger — adjust ScheduleByDay/DaysInterval for weekly (7) or monthly -->
      <StartBoundary>2026-04-03T0TRIGGER_HOUR:TRIGGER_MINUTE:00</StartBoundary>
      <Enabled>true</Enabled>
      <ScheduleByDay>
        <DaysInterval>1</DaysInterval>
      </ScheduleByDay>
    </CalendarTrigger>
  </Triggers>

  <Principals>
    <Principal id="Author">
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>

  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>true</RunOnlyIfNetworkAvailable>
    <IdleSettings>
      <StopOnIdleEnd>false</StopOnIdleEnd>
      <RestartOnIdle>false</RestartOnIdle>
    </IdleSettings>
    <!-- Hamilton Rule: hard kill at 2× expected runtime -->
    <ExecutionTimeLimit>PT10M</ExecutionTimeLimit>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <RunOnlyIfIdle>false</RunOnlyIfIdle>
    <WakeToRun>false</WakeToRun>
    <Priority>7</Priority>
    <!-- Retry once if failed, wait 5 minutes -->
    <RestartOnFailure>
      <Interval>PT5M</Interval>
      <Count>1</Count>
    </RestartOnFailure>
  </Settings>

  <Actions Context="Author">
    <Exec>
      <Command>python</Command>
      <Arguments>"G:\My Drive\Projects\_studio\AGENT_SCRIPT"</Arguments>
      <WorkingDirectory>G:\My Drive\Projects\_studio</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
